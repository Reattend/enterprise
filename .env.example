# Reattend Enterprise — environment variables reference.
#
# Copy this file to .env.local (dev) or .env (prod) and fill in values.
# Never commit the real filled version — .gitignore excludes .env*.local.

# ─── Required to boot the app ─────────────────────────────
# Random 32-byte secret. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# The public URL of the app. Dev: http://localhost:3000. Prod: https://reattend.com
NEXTAUTH_URL=http://localhost:3000

# ─── Required for AI (chat, task modes, wiki summaries) ───
# Pick ONE primary LLM. Anthropic is our default answering model.
ANTHROPIC_API_KEY=

# Optional: used for triage (cheaper/faster). Without this, triage falls back.
GROQ_API_KEY=

# ─── Optional: Google OAuth sign-in ───────────────────────
# Lets users sign in via "Continue with Google". Without it, only email-OTP login works.
# Register at https://console.cloud.google.com → OAuth consent screen + credentials.
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Optional: transactional email (OTP + enterprise invites) ──
# Without this, OTP codes are logged to the server console (dev mode).
# Resend is the default; swap for any SMTP provider by editing src/lib/email.ts.
RESEND_API_KEY=

# ─── Optional: Nango integrations (Gmail / Slack / Drive etc.) ──
# Phase A (first deploy): leave blank. Integrations panel shows the yellow
# "not configured" banner, nothing breaks. You can ship the product without these.
# Phase B (after self-hosting Nango via docker-compose.nango.yml on this
# droplet or another): fill in.
# NANGO_HOST=https://nango.reattend.com
# NANGO_SECRET_KEY=
# NANGO_WEBHOOK_SECRET=

# ─── Optional: Microsoft OAuth (for Outlook/Teams integrations via Nango) ──
# Only needed when you wire up M365 providers.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# ─── Optional: admin + cron ───────────────────────────────
# Secret used to protect the admin login page at /admin/login (emergency
# break-glass; not the regular /app/admin). Random 32+ chars.
# ADMIN_SECRET=

# Used to authenticate cron calls (e.g. retention prune). Random 32+ chars.
# CRON_SECRET=

# ─── Enterprise onboarding behaviour ──────────────────────
# When 'true', new user signups require an enterprise invite + domain match.
# Leave unset for open signup (useful during local testing).
# ENTERPRISE_STRICT_ONBOARDING=true
